# Loxone Smart Home Configuration
# Copy this file to .env and update with your actual values

# ========================================
# GENERAL SETTINGS
# ========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_TIMEZONE=Europe/Prague

# ========================================
# MODULE ENABLE/DISABLE
# ========================================
UDP_LISTENER_ENABLED=true
MQTT_BRIDGE_ENABLED=true
WEATHER_SCRAPER_ENABLED=true
GROWATT_CONTROLLER_ENABLED=true
OTE_COLLECTOR_ENABLED=true

# ========================================
# MQTT CONFIGURATION
# ========================================
MQTT_BROKER=mqtt
MQTT_PORT=1883
# Optional: Leave empty if no authentication
MQTT_USERNAME=
MQTT_PASSWORD=

# Topics to bridge from MQTT to Loxone (comma-separated)
# These messages will be forwarded to Loxone via UDP
MQTT_TOPICS=energy/solar,teplomer/TC,teslamate/cars/1/battery_level

# ========================================
# INFLUXDB CONFIGURATION
# ========================================
INFLUXDB_HOST=http://influxdb:8086
INFLUXDB_TOKEN=your-influxdb-token-here
INFLUXDB_ORG=tmarek
INFLUXDB_BUCKET=loxone

# ========================================
# UDP LISTENER (Loxone → InfluxDB)
# ========================================
# Listen for UDP packets from Loxone on this port
UDP_LISTENER_HOST=0.0.0.0
UDP_LISTENER_PORT=2000

# ========================================
# LOXONE BRIDGE (MQTT → Loxone)
# ========================================
# Your Loxone Miniserver IP address
LOXONE_HOST=192.168.1.100
# UDP port for sending data to Loxone
LOXONE_PORT=4000

# ========================================
# WEATHER CONFIGURATION
# ========================================
# Service: openmeteo, aladin, openweathermap
USE_SERVICE=openmeteo

# Your location coordinates
LATITUDE=49.00642
LONGITUDE=14.51994

# Optional: Only needed if USE_SERVICE=openweathermap
OPENWEATHERMAP_API_KEY=

# ========================================
# GROWATT SOLAR INVERTER CONFIGURATION
# ========================================
# Enable simulation mode for testing without hardware
GROWATT_SIMULATION_MODE=false

# ========================================
# GROWATT BATTERY OPTIMIZATION SETTINGS
# ========================================

# Battery Physical Parameters
# ---------------------------
GROWATT_BATTERY_CAPACITY=10.0            # Battery capacity in kWh
GROWATT_MIN_SOC=20.0                     # Minimum SOC to maintain (%)
GROWATT_MAX_SOC=100.0                    # Maximum SOC for charging (%)
GROWATT_DISCHARGE_MIN_SOC=20.0           # Stop discharge at this SOC (%)

# Battery Parameters
# ------------------
GROWATT_BATTERY_EFFICIENCY=0.85          # Round-trip efficiency (15% loss)
GROWATT_DISCHARGE_POWER_RATE=25          # Discharge power rate % (25 = gentle)

# Simple Price Thresholds (all in CZK/kWh)
# -----------------------------------------
GROWATT_CHARGE_PRICE_MAX=1.5             # Charge battery when price below this
GROWATT_EXPORT_PRICE_MIN=1.0             # Export solar production when price above this
GROWATT_DISCHARGE_PRICE_MIN=3.0          # Discharge battery to grid when price above this
GROWATT_DISCHARGE_PROFIT_MARGIN=1.5      # Required profit margin (1.5 = 50% profit)

# Charging Strategy
# -----------------
# Number of 15-minute blocks for battery charging at cheapest rates (non-consecutive)
# 4 blocks = 1 hour, 8 blocks = 2 hours (default), 12 blocks = 3 hours
GROWATT_BATTERY_CHARGE_BLOCKS=8


# Command Control Parameters
# --------------------------
# Delay between inverter commands (seconds)
GROWATT_COMMAND_DELAY=1.0

# Maximum retry attempts for failed commands
GROWATT_COMMAND_RETRY_COUNT=3

# Initial delay between retries (seconds, uses exponential backoff)
GROWATT_COMMAND_RETRY_DELAY=2.0

# Command timeout (seconds)
GROWATT_COMMAND_TIMEOUT=5.0

# Scheduling
# ----------

# Season Detection
# ----------------
# Consider summer mode when average temp exceeds (°C)
GROWATT_SUMMER_TEMP_THRESHOLD=15.0

# Summer mode price threshold (CZK/kWh, below operator costs)

# Days to average for temperature calculation
GROWATT_TEMPERATURE_AVG_DAYS=3

# Currency
# --------
# EUR to CZK exchange rate
GROWATT_EUR_CZK_RATE=25.0

# ========================================
# OTE ELECTRICITY PRICE COLLECTOR
# ========================================
# Delay between API requests (seconds)
OTE_REQUEST_DELAY=1.0

# Delay after errors (seconds)
OTE_ERROR_DELAY=5.0

# Maximum retries per request
OTE_MAX_RETRIES=3

# Historical data to load on first run (days, 1095 = 3 years)
OTE_LOAD_HISTORICAL_DAYS=1095

# Start checking for tomorrow's prices at this hour (14 = 2 PM)
OTE_FIRST_CHECK_HOUR=14

# Stop checking at this hour (18 = 6 PM)
OTE_MAX_CHECK_HOUR=18

# ========================================
# ADVANCED MQTT TOPICS (Usually don't need to change)
# ========================================
# These are the MQTT topics used for Growatt control
# Only modify if your Growatt integration uses different topics

# Battery-first mode control
GROWATT_BATTERY_FIRST_TOPIC=energy/solar/command/batteryfirst/set/timeslot
GROWATT_AC_CHARGE_TOPIC=energy/solar/command/batteryfirst/set/acchargeenabled

# Export control
GROWATT_EXPORT_ENABLE_TOPIC=energy/solar/command/export/enable
GROWATT_EXPORT_DISABLE_TOPIC=energy/solar/command/export/disable

# Grid-first mode control
GROWATT_GRID_FIRST_TOPIC=energy/solar/command/gridfirst/set/timeslot
GROWATT_GRID_FIRST_STOPSOC_TOPIC=energy/solar/command/gridfirst/set/stopsoc
GROWATT_GRID_FIRST_POWERRATE_TOPIC=energy/solar/command/gridfirst/set/powerrate

# Load-first mode control
GROWATT_LOAD_FIRST_STOPSOC_TOPIC=energy/solar/command/loadfirst/set/stopsoc